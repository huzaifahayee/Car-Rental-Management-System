# Local development backend URL. Change this value in your untracked .env file
# when using a deployed backend.
VITE_API_BASE_URL=http://localhost:5000

# Google Maps — Places Autocomplete + Maps JS API (client-side)
# Restrict this key by HTTP referrer in Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
