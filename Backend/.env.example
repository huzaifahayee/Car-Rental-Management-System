# Database connection string (change credentials for your local setup)
DATABASE_URL="postgresql://garitrip_user:your_password@localhost:5432/garitrip_dev?schema=public"

JWT_SECRET=your_jwt_secret_here

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Maps — server-side geocoding verification
# Restrict this key to the Geocoding API + your server's IP in Google Cloud Console
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key
